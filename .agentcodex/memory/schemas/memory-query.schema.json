{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcodex.local/schemas/memory-query.schema.json",
  "title": "Memory Query",
  "type": "object",
  "additionalProperties": true,
  "required": ["query", "task_type", "limits"],
  "properties": {
    "query": { "type": "string", "minLength": 1 },
    "task_type": { "type": "string", "minLength": 1 },
    "scope_filter": {
      "type": "object",
      "properties": {
        "scope": { "type": ["string", "null"] },
        "scope_value": { "type": ["string", "null"] }
      }
    },
    "limits": {
      "type": "object",
      "required": ["semantic", "episodic", "procedural"],
      "properties": {
        "semantic": { "type": "integer", "minimum": 0 },
        "episodic": { "type": "integer", "minimum": 0 },
        "procedural": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
