{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcodex.local/schemas/memory-write-event.schema.json",
  "title": "Memory Write Event",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "event_id",
    "event_type",
    "memory_type",
    "memory_id",
    "source",
    "owner",
    "timestamp"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": { "type": "string", "enum": ["append", "update-by-id", "merge-near-duplicate", "reject"] },
    "memory_type": { "type": "string", "enum": ["semantic", "episodic", "procedural"] },
    "memory_id": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "issues": { "type": "array", "items": { "type": "string" } },
    "target_snapshot": { "type": "string" }
  }
}
