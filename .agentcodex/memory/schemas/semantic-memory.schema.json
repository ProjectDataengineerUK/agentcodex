{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcodex.local/schemas/semantic-memory.schema.json",
  "title": "Semantic Memory",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "memory_id",
    "memory_type",
    "scope",
    "subject",
    "canonical_fact",
    "supporting_context",
    "confidence",
    "source",
    "created_at",
    "updated_at",
    "tags",
    "sensitivity",
    "retention_policy",
    "owner"
  ],
  "properties": {
    "memory_id": { "type": "string", "minLength": 1 },
    "memory_type": { "type": "string", "const": "semantic" },
    "scope": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "session", "project", "team", "org"]
        },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "subject": { "type": "string", "minLength": 1 },
    "canonical_fact": { "type": "string", "minLength": 1 },
    "supporting_context": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "source": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "sensitivity": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "retention_policy": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 }
  }
}
