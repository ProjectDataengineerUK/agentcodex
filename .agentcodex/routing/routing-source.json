{
  "version": "0.1.0",
  "workflow_phase_routing": [
    {
      "situation": "idea is vague, options need comparison",
      "preferred_role": "workflow-brainstormer"
    },
    {
      "situation": "requirements are unclear or incomplete",
      "preferred_role": "workflow-definer"
    },
    {
      "situation": "architecture or file manifest is needed",
      "preferred_role": "workflow-designer"
    },
    {
      "situation": "implementation should start from a defined design",
      "preferred_role": "workflow-builder"
    },
    {
      "situation": "work is ready for closure and archival",
      "preferred_role": "workflow-shipper"
    },
    {
      "situation": "existing workflow artifacts are stale and need propagation",
      "preferred_role": "workflow-iterator"
    }
  ],
  "data_engineering_routing": [
    {
      "task_shape": "initial evidence gathering before domain, platform, or control routing is clear",
      "preferred_role": "explorer"
    },
    {
      "task_shape": "final bug, regression, test, or implementation risk inspection after meaningful change",
