{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcodex.local/schemas/retrieval-index.schema.json",
  "title": "AgentCodex Retrieval Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "scope",
    "retrieval_priority",
    "area_domains",
    "entry_count",
    "views",
    "entries"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "retrieval_priority": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["layer", "priority"],
        "properties": {
          "layer": {
            "type": "string",
            "enum": [
              "summaries",
              "manifests",
              "kb-pages",
              "docs-complementary",
              "upstream-raw"
            ]
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          }
        }
      }
    },
    "area_domains": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        }
      }
    },
    "entry_count": {
      "type": "integer",
      "minimum": 0
    },
    "views": {
      "type": "object",
      "additionalProperties": false,
      "required": ["by_domain", "by_platform", "by_control", "by_integration"],
      "properties": {
        "by_domain": { "$ref": "#/$defs/viewMap" },
        "by_platform": { "$ref": "#/$defs/viewMap" },
        "by_control": { "$ref": "#/$defs/viewMap" },
        "by_integration": { "$ref": "#/$defs/viewMap" }
      }
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "viewEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "layer", "priority", "kind", "source_id"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "layer": {
          "type": "string",
          "enum": [
            "summaries",
            "manifests",
            "kb-pages",
            "docs-complementary",
            "upstream-raw"
          ]
        },
        "priority": { "type": "integer", "minimum": 1, "maximum": 5 },
        "kind": { "type": "string", "minLength": 1 },
        "source_id": { "type": "string" }
      }
    },
    "viewMap": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/$defs/viewEntry" }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "layer",
        "priority",
        "domain",
        "source_id",
        "kind",
        "area",
        "bucket_tags",
        "snippet"
      ],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "layer": {
          "type": "string",
          "enum": [
            "summaries",
            "manifests",
            "kb-pages",
            "docs-complementary",
            "upstream-raw"
          ]
        },
        "priority": { "type": "integer", "minimum": 1, "maximum": 5 },
        "domain": { "type": "string", "minLength": 1 },
        "source_id": { "type": "string" },
        "kind": { "type": "string", "minLength": 1 },
        "area": { "type": "string" },
        "bucket_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["platform", "control", "integration"]
          }
        },
        "snippet": { "type": "string" }
      }
    }
  }
}

