{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcodex.local/schemas/repos-lock.schema.json",
  "title": "AgentCodex Repos Lock",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "entries"],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "entries": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_id",
              "observed_ref",
              "observed_at",
              "update_status",
              "notes"
            ],
            "properties": {
              "source_id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "observed_ref": {
                "type": "string"
              },
              "observed_at": {
                "type": "string",
                "format": "date-time"
              },
              "update_status": {
                "type": "string",
                "enum": ["pending", "synced", "drifted", "blocked", "ignored"]
              },
              "notes": {
                "type": "string"
              }
            }
          }
        },
        {
          "type": "string",
          "const": "[]"
        }
      ]
    }
  }
}

