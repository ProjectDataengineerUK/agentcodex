{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcodex.local/schemas/sources.schema.json",
  "title": "AgentCodex Sources Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "sources"],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "repo",
          "category",
          "trust",
          "ingest_mode",
          "update_strategy"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "repo": {
            "type": "string",
            "pattern": "^https://github\\.com/[^/]+/[^/]+/?$"
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "trust": {
            "type": "string",
            "enum": ["official", "public-trusted", "community-reviewed"]
          },
          "ingest_mode": {
            "type": "string",
            "enum": ["metadata-first", "docs-first", "summary-first"]
          },
          "update_strategy": {
            "type": "string",
            "enum": ["periodic", "manual", "release-driven", "commit-watch"]
          }
        }
      }
    }
  }
}

